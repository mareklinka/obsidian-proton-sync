{
  "name": "obsidian-proton-drive-sync",
  "version": "0.3.2",
  "description": "Sync Obsidian vaults with Proton Drive",
  "author": "mareklinka",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "sync-version": "node scripts/sync-version.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@protontech/drive-sdk": "^0.19.2",
    "bcryptjs": "^3.0.3",
    "buffer": "^6.0.3",
    "effect": "^3.22.0",
    "openpgp": "^6.3.1",
    "picomatch": "^4.0.5",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@effect/language-service": "^0.87.0",
    "@eslint/js": "^10.0.1",
    "@openpgp/web-stream-tools": "^0.3.1",
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "obsidian": "^1.13.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
