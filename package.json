{
  "name": "obsidian-proton-drive-sync",
  "version": "0.3.0",
  "description": "Sync Obsidian vaults with Proton Drive",
  "author": "mareklinka",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "sync-version": "node scripts/sync-version.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@protontech/drive-sdk": "^0.14.1",
    "bcryptjs": "^3.0.3",
    "buffer": "^6.0.3",
    "effect": "^3.21.0",
    "openpgp": "^6.3.0",
    "picomatch": "^4.0.4",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.1",
    "@eslint/js": "10.0.1",
    "@openpgp/web-stream-tools": "^0.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "obsidian": "1.12.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
